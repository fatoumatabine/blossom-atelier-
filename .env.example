# Database
DATABASE_URL=postgresql://user:password@host/database

# JWT Configuration (generate with: node -e "console.log(crypto.randomBytes(32).toString('hex'))")
JWT_SECRET=YOUR_SECRET_KEY_CHANGE_IN_PRODUCTION_MIN_32_CHARS

# Admin Setup Key (generate with: node -e "console.log(crypto.randomBytes(24).toString('hex'))")
ADMIN_SETUP_KEY=YOUR_ADMIN_SETUP_KEY_CHANGE_IN_PRODUCTION

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=your_folder

# Environment
NODE_ENV=production

# Optional: Seed demo data in development
SEED_DEMO_DATA=false
